{
  "name": "Python 3",
  "image": "mcr.microsoft.com/devcontainers/base:noble",
  "features": {
   "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13"
    }
  },
  "forwardPorts": [8000],
  "postCreateCommand": "pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "ms-python.python",
        "ms-python.debugpy"
      ]
    }
  }
}
